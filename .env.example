# transfer deployment configuration
# Copy to .env and adjust values. Do NOT commit the resulting .env.

# Override the container image if you maintain your own build or want to pin a
# specific version. Leave unset to use the default (ghcr.io/xenofex7/transfer:latest).
#TRANSFER_IMAGE=ghcr.io/xenofex7/transfer:1.0.0

# Host path that backs /data inside the container. Defaults to ./data next to
# the compose file. Set to an absolute path for production setups, e.g.
#   DATA_DIR=/volume1/docker/transfer/data
DATA_DIR=./data

# Host directory holding the htpasswd file. Mounted at /etc/transfer inside
# the container. Must be owned by UID 65532 (the transfersh container user)
# so the /admin/users UI can add/reset/delete users in place.
#   sudo chown -R 65532:65532 ./auth
AUTH_DIR=./auth

# External Docker network shared with your reverse proxy (e.g. Nginx Proxy Manager).
# Run `docker network ls` to find the right name; common values:
#   - "proxy"           (custom shared network)
#   - "nginx_default"   (default network of an NPM compose project named "nginx")
PROXY_NETWORK=proxy

# Auto-purge: files are removed after PURGE_DAYS days at the latest; the
# cleanup loop runs every PURGE_INTERVAL hours and also removes uploads whose
# per-file expiry (see the TTL settings below) has passed.
PURGE_DAYS=360
PURGE_INTERVAL=1

# Upload tiers
# Anonymous (no login): small files, short retention.
ANON_UPLOADS=true         # set to false to require a login for every upload
ANON_MAX_UPLOAD_SIZE=51200    # in KB, default 50 MB
ANON_UPLOAD_TTL=24h       # anonymous uploads expire and are deleted after this
# Signed-in users: big files, long retention.
MAX_UPLOAD_SIZE=10485760  # in KB, default 10 GB
AUTH_UPLOAD_TTL=4320h     # 180 days; uploads by signed-in users expire after this
RATE_LIMIT=0              # requests per minute, 0 disables

# URL token length (longer = harder to guess)
RANDOM_TOKEN_LENGTH=10

# Comma-separated CIDRs that may upload without basic auth (optional).
HTTP_AUTH_IP_WHITELIST=

# Comma-separated CIDRs allowed / denied at the connection level (optional).
IP_WHITELIST=
IP_BLACKLIST=

# CORS: comma-separated list of allowed origins (optional).
CORS_DOMAINS=

# Set when running behind a reverse proxy on a non-standard path / port.
PROXY_PATH=
PROXY_PORT=

# Frontend "Contact us" mail link (optional).
EMAIL_CONTACT=

# Tagline shown beneath the hostname on the homepage. Set to empty to hide.
TAGLINE=Like WeTransfer - but it stays at your place

# Optional: URL that receives a JSON POST for upload / download / delete events.
# Body shape: {"event":"upload"|"download"|"delete","filename":"...",
#              "content_type":"...","size":N,"url":"...","delete_url":"...",
#              "user":"...","downloads":N}
# Best-effort, async, no retry.
UPLOAD_WEBHOOK_URL=

# Optional: bearer token sent as `Authorization: Bearer <token>` on every
# webhook POST. Use this if your receiver verifies a shared secret.
WEBHOOK_TOKEN=

# Optional: Umami visitor analytics on user-facing pages (homepage,
# downloads, 404). Admin pages never carry the tag. Empty disables
# visitor tracking entirely.
# The anonymous instance heartbeat is on by default and is toggled
# from /admin/settings - see README for env-level overrides.
UMAMI_SCRIPT_URL=
UMAMI_WEBSITE_ID=

# Resource limit for the transfer container.
TRANSFER_MEMORY_LIMIT=512M
